<body class="h-screen w-screen flex flex-col justify-between p-6">

    <div id="fullscreen-overlay" class="fixed inset-0 bg-slate-950/90 z-50 flex flex-col items-center justify-center text-center p-4">
        <div class="glass-panel p-8 rounded-2xl max-w-md border-surau-gold border">
            <h2 class="text-2xl font-bold text-surau-gold mb-4">Sistem Paparan Surau</h2>
            <p class="text-gray-300 mb-6">Sila klik butang di bawah untuk mengaktifkan mod skrin penuh (Full Screen Mode).</p>
            <button onclick="activateFullscreen()" class="bg-surau-gold text-slate-950 font-bold px-6 py-3 rounded-xl hover:bg-amber-400 transition-all text-lg shadow-lg shadow-amber-500/20 w-full">
                Buka Skrin Penuh
